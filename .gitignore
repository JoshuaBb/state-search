.gitignore# Rust build artifacts
/target/
.idea/

/exports
# SQLx offline query cache (only needed if using compile-time query! macros)
.sqlx/

# Environment secrets
.env
.env.*
!.env.example

# CSV data files — ingest locally but do not commit
/data/

# IDE — JetBrains (workspace-level; .idea/.gitignore handles per-IDE files)
/.idea/workspace.xml
/.idea/tasks.xml
/.idea/*.iml
/.idea/modules.xml
/.idea/.name
# Keep: .idea/runConfigurations/, .idea/inspectionProfiles/, .idea/.gitignore

# macOS
.DS_Store

# Windows
Thumbs.db

# Linux
*~

# Editor swap files
*.swp
*.swo
.vscode/settings.json

# Claude Code session data
/.claude/

# Docker build context artifacts
*.tar.gz

# Postgres data directory (bind-mounted from docker-compose)
/pgdata/
.worktrees/
